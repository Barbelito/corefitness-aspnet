@model MyAccountViewModel

@{
    ViewData["Title"] = "My Account";
}
<div class="account-layout">
    <div class="container">
        <aside>
            <div class="profile-image">
                @if (!string.IsNullOrWhiteSpace(Model.ProfileImageUri))
                {
                    <img src="@Url.Content(Model.ProfileImageUri)" alt="User Profile Image" />
                }
                else
                {
                    <img src="~/images/profile-image-avatar.png" alt="user profile image" />
                }

            </div>

            <nav class="account-options-menu options-menu">
                <div class="options-menu-title">
                    Options Menu
                </div>
                <ul class="options">
                    <li class="option-item">
                        <a class="option-item-link" asp-area="Account" asp-controller="Account" asp-action="My">About Me</a>
                    </li>
                    <li class="option-item">
                        <a class="option-item-link" asp-area="Account" asp-controller="AccountMembership" asp-action="Index">My Membership</a>
                    </li>
                    <li class="option-item">
                        <a class="option-item-link" asp-area="Account" asp-controller="AccountBookings" asp-action="Index">My Bookings</a>
                    </li>
                    <li class="option-item">
                        <a class="option-item-link" asp-area="Account" asp-controller="Account" asp-action="SignOut">Sign Out</a>
                    </li>
                    <li class="option-item">
                        <a class="option-item-link" asp-area="Account" asp-controller="Account" asp-action="DeleteAccount">Delete Account</a>
                    </li>

                </ul>
            </nav>
            <div class="delete-account-block">
                <p class="delete-account-text">If you like to cancel your account click below</p>
                <a class="delete-account-link" asp-area="Account" asp-controller="Account" asp-action="DeleteAccount">Remove Account</a>
            </div>

        </aside>
        <main>
            <section class="about-me">
                <div class="title">
                    <h3>About Me</h3>
                    <hr />
                </div>
                <form id="aboutMeForm" method="post" enctype="multipart/form-data" asp-area="Account" asp-controller="Account" asp-action="My" novalidate>
                    <div data-type="firstname" class="form-group">
                        <label class="form-label" asp-for="AboutMeForm.FirstName"></label>
                        <input class="form-input" asp-for="AboutMeForm.FirstName" />
                        <span class="form-field-validation" asp-validation-for="AboutMeForm.FirstName"></span>
                    </div>
                    <div data-type="lastname" class="form-group">
                        <label class="form-label" asp-for="AboutMeForm.LastName"></label>
                        <input class="form-input" asp-for="AboutMeForm.LastName" />
                        <span class="form-field-validation" asp-validation-for="AboutMeForm.LastName"></span>
                    </div>
                    <div data-type="email" class="form-group">
                        <label class="form-label" asp-for="AboutMeForm.Email"></label>
                        <input class="form-input" asp-for="AboutMeForm.Email" readonly />
                        <span class="form-field-validation" asp-validation-for="AboutMeForm.Email"></span>
                    </div>
                    <div data-type="phone" class="form-group">
                        <label class="form-label" asp-for="AboutMeForm.PhoneNumber"></label>
                        <input class="form-input" asp-for="AboutMeForm.PhoneNumber" />
                        <span class="form-field-validation" asp-validation-for="AboutMeForm.PhoneNumber"></span>
                    </div>
                    <hr />
                    <div data-type="file" class="form-group upload-group">
                        <label class="form-label" asp-for="AboutMeForm.ProfileImage"></label>

                        <div class="upload-display">
                            <input type="file" id="profileUpload" asp-for="AboutMeForm.ProfileImage" hidden />
                            <span id="fileName" class="file-name">Upload Profile Image</span>
                            <button type="button" class="upload-btn" onclick="document.getElementById('profileUpload').click()">Browse</button>
                        </div>

                        <span class="form-field-validation" asp-validation-for="AboutMeForm.ProfileImage"></span>
                    </div>

                    <div data-type="submit" class="form-group">
                        <button class="btn" type="submit">Save</button>
                    </div>

                    <div asp-validation-summary="ModelOnly"></div>
                    @Html.AntiForgeryToken()
                </form>
            </section>

            <section class="my-statistics-section">
                <h3>My Statistics</h3>
                <hr />
                <div class="statistic">
                    <div class="stat-header">
                        <h4>Check-In (last 30 days)</h4>
                        <span class="stat-value">25</span>
                    </div>

                    <div class="stat-bar">
                        <div class="stat-bar-fill" style="--value: 80%"></div>
                    </div>
                </div>

                <div class="statistic">
                    <div class="stat-header">
                        <h4>Weight Goal</h4>
                        <span class="stat-value">50%</span>
                    </div>

                    <div class="stat-bar">
                        <div class="stat-bar-fill" style="--value: 50%"></div>
                    </div>
                </div>

                <div class="statistic">
                    <div class="stat-header">
                        <h4>Current BMI</h4>
                        <span class="stat-value">27</span>
                    </div>

                    <div class="stat-bar">
                        <div class="stat-bar-fill" style="--value: 65%"></div>
                    </div>
                </div>

                
            </section>

        </main>
    </div>
</div>