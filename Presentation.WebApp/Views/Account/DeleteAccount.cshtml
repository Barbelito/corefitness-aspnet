@{
    Layout = "Layouts/_AuthLayout";
    ViewData["Title"] = "Delete Account";
}

<section class="delete-account">
    <h1>Delete Account</h1>
    <p>This action cannot be undone. Are you sure you want to delete your account?</p>

    <form method="post" asp-action="DeleteAccount" class="delete-account-form">
        <button class="btn delete-btn" type="submit">Yes, delete my account</button>
        <a class="btn cancel-btn" asp-action="My">Cancel</a>
    </form>
</section>
