@{

}

<section class="section__header">
    <div class="logotype">
        <a href="/"><img src="~/images/logotype.png" alt="CoreFitness Logotype" /></a>
    </div>
    <nav class="main-menu">
        <ul class="menu">
            <li class="menu-item">
                <a class="menu-item-link" asp-action="Index" asp-controller="FitnessCenters">Fitness Centers</a>
            </li>
            <li class="menu-item">
                <a class="menu-item-link" asp-action="Index" asp-controller="Memberships">Memberships</a>
            </li>
            <li class="menu-item">
                <a class="menu-item-link" asp-action="Index" asp-controller="Training">Training</a>
            </li>
            <li class="menu-item">
                <a class="menu-item-link" asp-action="Index" asp-controller="Support">Customer Service</a>
            </li>
        </ul>
    </nav>
    <nav class="account-menu">
        <ul class="menu">
            @if (User.Identity?.IsAuthenticated ?? false)
            {
                <li class="menu-item">
                    <a class="menu-item-link" asp-area="Authentication" asp-controller="Authentication" asp-action="SignOut">Sign Out</a>
                </li>
                <li class="menu-item">
                    <a class="btn menu-item-button" asp-controller="Account" asp-action="My">My Account</a>
                </li>
            }
            else
            {
                <li class="menu-item">
                    <a class="menu-item-link" asp-area="Authentication" asp-controller="Authentication" asp-action="SignUp">Become Member</a>
                </li>

                <li class="menu-item">
                    <a class="btn accent" asp-area="Authentication" asp-controller="Authentication" asp-action="SignIn">Sign In</a>
                </li>
            }
            


        </ul>
    </nav>

    <button id="mobile-menu-button" data-target="#mobile-menu-flyout" class="mobile-btn accent"></button>

</section>