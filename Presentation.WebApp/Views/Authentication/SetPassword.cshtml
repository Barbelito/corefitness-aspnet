@model RegisterPasswordForm

@{
    Layout = "Layouts/_AuthLayout";
    ViewData["Title"] = "Set Your Password";
}
<div class="page__auth-signin">

    <section class="section__auth">
        <div class="title">
            <h1>Set Your Password</h1>
            <p>Set a strong password to protect your account. For security reasons, your password must be at least 8 characters long and include uppercase and lowercase letters, numbers, and special characters.</p>
        </div>
        
        <hr />

        <form method="post" asp-action="SetPassword" asp-controller="Authentication" novalidate>
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label" asp-for="Password"></label>
                <input class="form-input" asp-for="Password" />
                <span class="field-validation-error" asp-validation-for="Password"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="ConfirmPassword"></label>
                <input class="form-input" asp-for="ConfirmPassword" />
                <span class="field-validation-error" asp-validation-for="Password"></span>
            </div>

            <button class="btn" type="submit">Continue</button>


            <div data-type="terms" class="form-group form-checkbox-group">
                <input class="form-checkbox" asp-for="TermsAndConditions" />
                <label class="form-checkbox-label" asp-for="TermsAndConditions">Accept user terms and conditions</label>
            </div>
            <div class="form-errormessage">
                <span class="form-field-validation" asp-validation-for="TermsAndConditions"></span>
            </div>

            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
        </form>

    </section>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }



</div>